import streamlit as st

def login_page(supabase):
    # --- 1. GIAO DIỆN LOGIN ---
    st.markdown("""
        <style>
        .login-container {
            max-width: 400px;
            margin: auto;
            padding: 40px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border: 1px solid #d2d2d7;
            text-align: center;
        }
        .stButton>button {
            width: 100%;
            border-radius: 10px;
            height: 45px;
            background-color: #0071e3;
            color: white;
            font-weight: 600;
        }
        </style>
    """, unsafe_allow_html=True)

    # Căn giữa form đăng nhập
    _, center_col, _ = st.columns([1, 2, 1])

    with center_col:
        st.markdown('<div class="login-container">', unsafe_allow_html=True)
        st.image("https://cdn-icons-png.flaticon.com/512/2592/2592261.png", width=80)
        st.markdown("## Đăng nhập hệ thống")
        st.markdown("<p style='color: #86868b;'>Vui lòng nhập tài khoản quản trị</p>", unsafe_allow_html=True)

        with st.form("login_form"):
            email = st.text_input("Email công ty", placeholder="admin@company.com")
            password = st.text_input("Mật khẩu", type="password", placeholder="••••••••")
            submit = st.form_submit_button("Đăng nhập")

            if submit:
                if email and password:
                    try:
                        # Xác thực với Supabase Auth
                        response = supabase.auth.sign_in_with_password({
                            "email": email,
                            "password": password
                        })
                        if response.user:
                            st.session_state.authenticated = True
                            st.session_state.user_email = response.user.email
                            st.success("Đăng nhập thành công!")
                            st.rerun()
                    except Exception as e:
                        st.error("Email hoặc mật khẩu không chính xác.")
                else:
                    st.warning("Vui lòng điền đầy đủ thông tin.")
        
        st.markdown('</div>', unsafe_allow_html=True)
        st.caption("© 2026 Enterprise Asset Management System")
